<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Щит (shield shape) -->
    <path
        android:pathData="M54,22 L78,34 L78,56 C78,70 68,82 54,88 C40,82 30,70 30,56 L30,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="30"
                android:startY="22"
                android:endX="78"
                android:endY="88"
                android:type="linear">
                <item android:color="#3300D4FF" android:offset="0.0" />
                <item android:color="#1A6C63FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Контур щита -->
    <path
        android:pathData="M54,22 L78,34 L78,56 C78,70 68,82 54,88 C40,82 30,70 30,56 L30,34 Z"
        android:strokeWidth="2.5"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="22"
                android:endX="78"
                android:endY="88"
                android:type="linear">
                <item android:color="#FF00D4FF" android:offset="0.0" />
                <item android:color="#FF6C63FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Стрелка вверх (DNS switch) -->
    <path
        android:pathData="M46,62 L46,48 L40,48 L50,38 L60,48 L54,48 L54,54"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="40"
                android:startY="38"
                android:endX="60"
                android:endY="62"
                android:type="linear">
                <item android:color="#FF00D4FF" android:offset="0.0" />
                <item android:color="#FF00E676" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Стрелка вниз (DNS switch) -->
    <path
        android:pathData="M62,46 L62,60 L68,60 L58,70 L48,60 L54,60 L54,54"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="48"
                android:startY="46"
                android:endX="68"
                android:endY="70"
                android:type="linear">
                <item android:color="#FF6C63FF" android:offset="0.0" />
                <item android:color="#FF00D4FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>